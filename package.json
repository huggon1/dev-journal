{
  "name": "dev-journal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run build:types && vite build",
    "start": "node build/src/server/index.js",
    "test": "npm run build:types && node --test \"build/tests/**/*.test.js\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
